{
  "$ref": "#/definitions/get_scene_summaryOutput",
  "definitions": {
    "get_scene_summaryOutput": {
      "type": "object",
      "properties": {
        "audit": {
          "type": "object",
          "properties": {
            "agentId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "agentName": {
              "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/agentId"
            },
            "foundrySessionId": {
              "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/agentId"
            },
            "foundryUserId": {
              "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/agentId"
            },
            "requestId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "requestId",
            "timestamp"
          ],
          "additionalProperties": false
        },
        "data": {
          "type": "object",
          "properties": {
            "scene": {
              "type": "object",
              "properties": {
                "active": {
                  "type": "boolean"
                },
                "height": {
                  "type": "number"
                },
                "id": {
                  "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/requestId"
                },
                "name": {
                  "type": "string"
                },
                "notes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/requestId"
                      },
                      "img": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "parentId": {
                        "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/requestId"
                      },
                      "sceneId": {
                        "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/requestId"
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "JournalEntry",
                          "Actor",
                          "Item",
                          "Note",
                          "Folder",
                          "RollTable",
                          "Playlist",
                          "Scene"
                        ]
                      }
                    },
                    "required": [
                      "id",
                      "name",
                      "type"
                    ],
                    "additionalProperties": false
                  }
                },
                "noteCount": {
                  "type": "integer",
                  "minimum": 0
                },
                "width": {
                  "type": "number"
                }
              },
              "required": [
                "active",
                "id",
                "name",
                "notes",
                "noteCount"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "scene"
          ],
          "additionalProperties": false
        },
        "error": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string",
                  "minLength": 1
                },
                "details": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "null"
                    },
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/definitions/get_scene_summaryOutput/properties/error/anyOf/0/properties/details"
                      }
                    },
                    {
                      "type": "object",
                      "additionalProperties": {
                        "$ref": "#/definitions/get_scene_summaryOutput/properties/error/anyOf/0/properties/details"
                      }
                    }
                  ]
                },
                "message": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "code",
                "message"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        },
        "ok": {
          "type": "boolean"
        },
        "requestId": {
          "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/requestId"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "timestamp": {
          "$ref": "#/definitions/get_scene_summaryOutput/properties/audit/properties/timestamp"
        },
        "tool": {
          "type": "string",
          "enum": [
            "find_documents",
            "get_document",
            "list_folders",
            "get_scene_summary",
            "create_journal_entry",
            "update_journal_entry",
            "create_actor",
            "update_actor",
            "create_actor_item",
            "update_actor_item",
            "create_scene_note",
            "set_document_flags",
            "preview_change",
            "apply_approved_change"
          ]
        }
      },
      "required": [
        "audit",
        "data",
        "error",
        "ok",
        "requestId",
        "status",
        "timestamp",
        "tool"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
