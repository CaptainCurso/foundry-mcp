{
  "$ref": "#/definitions/create_scene_note",
  "definitions": {
    "create_scene_note": {
      "type": "object",
      "properties": {
        "approvalToken": {
          "type": "string",
          "minLength": 20,
          "maxLength": 300
        },
        "dryRun": {
          "type": "boolean"
        },
        "entryId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "namespace": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "pattern": "^[a-zA-Z0-9._-]+$",
                "default": "foundryvtt-mcp-bridge-module"
              },
              "key": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "pattern": "^[a-zA-Z0-9._-]+$"
              },
              "value": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  },
                  {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/create_scene_note/properties/flags/items/properties/value"
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": {
                      "$ref": "#/definitions/create_scene_note/properties/flags/items/properties/value"
                    }
                  }
                ]
              }
            },
            "required": [
              "key",
              "value"
            ],
            "additionalProperties": false
          },
          "maxItems": 20
        },
        "icon": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "requestContext": {
          "type": "object",
          "properties": {
            "agentId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "agentName": {
              "$ref": "#/definitions/create_scene_note/properties/requestContext/properties/agentId"
            },
            "sessionId": {
              "$ref": "#/definitions/create_scene_note/properties/requestContext/properties/agentId"
            },
            "userId": {
              "$ref": "#/definitions/create_scene_note/properties/requestContext/properties/agentId"
            }
          },
          "additionalProperties": false
        },
        "sceneId": {
          "$ref": "#/definitions/create_scene_note/properties/entryId"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "required": [
        "dryRun",
        "entryId",
        "sceneId",
        "x",
        "y"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
