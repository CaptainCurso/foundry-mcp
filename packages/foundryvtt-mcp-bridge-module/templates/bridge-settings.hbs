<form class="foundry-mcp-bridge-settings flexcol">
  <section class="form-group">
    <h2>Connection</h2>
    <p class="notes">These settings tell the module how to reach the MCP bridge server.</p>
  </section>

  <div class="form-group">
    <label for="serverUrl">Bridge Server URL</label>
    <input id="serverUrl" name="serverUrl" type="text" value="{{serverUrl}}" placeholder="http://127.0.0.1:3310" />
    <p class="notes">Use the HTTP address of the machine running the bridge server.</p>
  </div>

  <div class="form-group">
    <label for="serverToken">Bridge Bearer Token</label>
    <input id="serverToken" name="serverToken" type="password" value="{{serverToken}}" autocomplete="off" />
    <p class="notes">This must match the server's <code>BRIDGE_SHARED_TOKEN</code> value.</p>
  </div>

  <section class="form-group">
    <h2>Bridge Owner</h2>
    <p class="notes">The bridge only runs in the GM session owned by this user id.</p>
  </section>

  <div class="form-group">
    <label for="bridgeOwnerUserId">Bridge Owner User ID</label>
    <div class="form-fields">
      <input id="bridgeOwnerUserId" name="bridgeOwnerUserId" type="text" value="{{bridgeOwnerUserId}}" {{#unless canEditWorldSettings}}disabled{{/unless}} />
      {{#if isGM}}
      <button type="button" data-action="use-current-user">
        <i class="fas fa-user-check"></i> Use My User ID
      </button>
      {{/if}}
    </div>
    {{#unless canEditWorldSettings}}
    <p class="notes">Only GMs can change world-scoped settings.</p>
    {{/unless}}
  </div>

  {{#if isGM}}
  <div class="form-group">
    <label>GM Users</label>
    <div class="form-fields stacked">
      <ul>
        {{#each users}}
        {{#if this.isGM}}
        <li><code>{{this.id}}</code> - {{this.name}}</li>
        {{/if}}
        {{/each}}
      </ul>
    </div>
  </div>

  <section class="form-group">
    <h2>Safety Allowlists</h2>
    <p class="notes">Leave these conservative unless you intentionally want to widen what the bridge can write.</p>
  </section>

  <div class="form-group">
    <label for="allowedOperations">Allowed Operations</label>
    <textarea id="allowedOperations" name="allowedOperations" rows="4">{{allowedOperations}}</textarea>
    <p class="notes">Comma-separated tool names the module is allowed to execute.</p>
  </div>

  <div class="form-group">
    <label for="allowedFlagNamespaces">Allowed Flag Namespaces</label>
    <textarea id="allowedFlagNamespaces" name="allowedFlagNamespaces" rows="2">{{allowedFlagNamespaces}}</textarea>
    <p class="notes">Comma-separated flag namespaces. Start with the module-owned namespace unless you have a clear reason to expand it.</p>
  </div>

  <div class="form-group">
    <label for="allowedSystemPaths">Allowed System Paths</label>
    <textarea id="allowedSystemPaths" name="allowedSystemPaths" rows="4">{{allowedSystemPaths}}</textarea>
    <p class="notes">Comma-separated dotted paths inside <code>system</code> that writes may touch. Empty means deny all system writes.</p>
  </div>
  {{/if}}

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fas fa-save"></i> Save Settings
    </button>
  </footer>
</form>
